TZ=Europe/Madrid

# ── Secrets ──────────────────────────────────────────────────────────────────
# Generate each with:  openssl rand -base64 48
# NEVER commit the real .env (it is gitignored + chmod 600).
JWT_SECRET=CHANGE_ME
CSRF_SECRET=CHANGE_ME
COOKIE_SECRET=CHANGE_ME

# ── Initial admin ────────────────────────────────────────────────────────────
# Created on first boot ONLY if the users table is empty.
# TOTP enrollment is forced at first login — this password alone cannot reach
# the dashboard.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG

# ── Public origin ────────────────────────────────────────────────────────────
# Used for absolute links and Secure-cookie scoping.
PUBLIC_ORIGIN=https://photos.lenadesp.org

# ── Data directory (host) ────────────────────────────────────────────────────
# Optional. Host path bind-mounted to /data in the container. Defaults to ./data
# next to compose.yaml. Set an absolute path to store data elsewhere. The path
# inside the container is always /data.
# DATA_DIR=./data

# ── Upload limits ────────────────────────────────────────────────────────────
MAX_FILE_BYTES=52428800        # 50 MB per file on the batched multipart route
MAX_FILES_PER_UPLOAD=40        # per request (the frontend batches larger drops)
MAX_IMAGE_PIXELS=50000000      # 50 MP decode cap (decompression-bomb guard)
MIN_FREE_BYTES=1073741824      # refuse uploads below 1 GiB free (protects the SQLite WAL)

# Resumable uploads. Anything at or over MAX_FILE_BYTES is sent in parts instead,
# so a file larger than the reverse proxy's body ceiling can be uploaded at all.
UPLOAD_PART_BYTES=8388608      # 8 MiB per part — keep well under the proxy's body limit
MAX_UPLOAD_BYTES=2147483648    # 2 GiB ceiling for a single assembled file
STALE_UPLOAD_MS=86400000       # reclaim abandoned upload sessions after 24 h
